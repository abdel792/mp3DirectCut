#. Translators: The label of the checkbox to enable or disable the spacebar announcements.
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:32
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:62
msgid "Enable announcements of the space key"
msgstr "Activează anunțurile tastei spațiu"

#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:39
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:69
msgid "Announce the placement of the selection markers"
msgstr "Anunță plasarea marcajelor de selecție"

#. Translators: The label of the checkbox to enable or disable the other announcements.
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:44
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:74
msgid "Enable the other announces"
msgstr "Activează alte anunțuri"

#. Translators: The title of the add-on configuration dialog box.
#: addon\globalPlugins\mp3DirectCut\mp3DirectCutDialog.py:57
#, python-brace-format
msgid "Configuration of the addon {0}"
msgstr "Configurarea suplimentului {0}"

#. Translators: name of the option in the menu.
#: addon\globalPlugins\mp3DirectCut\__init__.py:55
#, python-brace-format
msgid "{0} addon configuration"
msgstr "Configurarea suplimentului {0}"

#. Translators: Message presented in input help mode.
#: addon\globalPlugins\mp3DirectCut\__init__.py:74
#, python-brace-format
msgid "Allows you display the configuration dialog of {0} addon."
msgstr "Vă permite să afișați dialogul de configurare al suplimentului {0}."

#: addon\appModules\mp3directcut.py:44
msgid "hours"
msgstr "ore"

#: addon\appModules\mp3directcut.py:44
msgid "minutes"
msgstr "minute"

#: addon\appModules\mp3directcut.py:44
msgid "seconds"
msgstr "secunde"

#: addon\appModules\mp3directcut.py:44
msgid "hundredths"
msgstr "sutimi"

#: addon\appModules\mp3directcut.py:44
msgid "thousandths"
msgstr "miimi"

#. Translators: Message to inform that no selection has been realized.
#: addon\appModules\mp3directcut.py:51
msgid "No selection"
msgstr "Fără selecție"

#. Translators: Message to inform the user that the playback cursor is at the top of the file.
#: addon\appModules\mp3directcut.py:53
msgid "Beginning of the file."
msgstr "Începutul fișierului"

#. Translators: Message to inform the user that the playback cursor is at the end of the file.
#: addon\appModules\mp3directcut.py:55
msgid "End of the file."
msgstr "Sfârșitul fișierului."

#. Translators: Message to inform the user that not file is loaded.
#: addon\appModules\mp3directcut.py:57
msgid "Not file is loaded. Please check that you are in a file, open one with Control O,\tor R to start recording."
msgstr ""

#. Translators: Message to inform the user that the current command is not available in a recording mode.
#: addon\appModules\mp3directcut.py:60
msgid "This command is not available in a recording mode, it is available only in a reading mode !"
msgstr "Această comandă nu este disponibilă în modul de înregistrare, ea funcționează doar în modul de citire."

#. Translators: Message to indicate the position of the selection start marker.
#: addon\appModules\mp3directcut.py:62
msgid "The marker of the beginning of selection B is at"
msgstr "Marcajul începutului selecției B este la"

#. Translators: Message to indicate the position of the selection end marker.
#: addon\appModules\mp3directcut.py:64
msgid "The marker of the End of selection N is at"
msgstr "Marcajul sfârșitului selecției N este la"

#. Translators: Message to indicate the level of the vu-meter.
#: addon\appModules\mp3directcut.py:66
msgid "The level of the vu-meter is at"
msgstr "Nivelul vu-meter-ului este la"

#. Translators: Message to indicate the total duration of the current file.
#: addon\appModules\mp3directcut.py:68
msgid "Total time: "
msgstr "Timp total: "

#. Translators: Message to indicate the duration of the selection.
#: addon\appModules\mp3directcut.py:70
msgid "Duration of selection"
msgstr "Durata selecției"

#. Translators: Message to indicate the actual part.
#: addon\appModules\mp3directcut.py:72
msgid "Actual part"
msgstr "Parte actuală"

#. Translators: Message to inform that no selection was found.
#: addon\appModules\mp3directcut.py:74
msgid "Selection not found."
msgstr "Selecție negăsită"

#. Translators: Message to indicate that the information of the current part is not available.
#: addon\appModules\mp3directcut.py:76
msgid "Information specific to the actual part is not available."
msgstr "Informația specifică pentru partea actuală nu este disponibilă."

#. Translators: Message to prompt the user to verify that no selection has been made.
#: addon\appModules\mp3directcut.py:78
msgid "Please check that no selection has been made."
msgstr "Vă rugăm să verificați dacă nicio selecție nu a fost făcută."

#. Translators: Message to prompt the user to verify that it is not in recording mode.
#: addon\appModules\mp3directcut.py:80
msgid "Please chek that you are not in a recording mode."
msgstr "Vă rugăm să verificați dacă nu sunteți în modul de înregistrare."

#. Translators: Message to inform the user that the recording is ready.
#: addon\appModules\mp3directcut.py:82
msgid "The recording is ready ! It remains only to press spacebar for begin the recording.\tThis same spacebar  will stop the recording !"
msgstr ""

#. Translators: Message to inform the user that a recording is in progress.
#: addon\appModules\mp3directcut.py:85
msgid "A recording is in progress, please press spacebar for stop it and start a new one."
msgstr "O înregistrare este în desfășurare, vă rugăm să apăsați spațiu pentru a o opri și a începe una nouă."

#. Translators: Message to inform the user that the recording is not ready.
#: addon\appModules\mp3directcut.py:87
msgid "The recording is not ready !"
msgstr "Înregistrarea nu este gata!"

#. Translators: Message to indicate that the vu-meter is not available.
#: addon\appModules\mp3directcut.py:89
#, python-brace-format
msgid "The vu-meter is not available. Please verify if a recording is in progress,\tand that the checkbox enable the margin button is checked in the options of {0}."
msgstr ""

#. Translators: Message to confirm that the level of the vu-meter has been reset.
#: addon\appModules\mp3directcut.py:92
msgid "The level of the vu-meter has been reset !"
msgstr "Nivelul vu-meter-ului a fost resetat!"

#. Translators: Message to confirm the placement of the selection start marker.
#: addon\appModules\mp3directcut.py:94
msgid "Start selection marker set."
msgstr "Începutul marcajului de selecție a fost setat."

#. Translators: Message to confirm the placement of the selection end marker.
#: addon\appModules\mp3directcut.py:96
msgid "End selection marker set."
msgstr "Sfârșitul marcajului de selecție a fost setat."

#. Translators: Message to confirm that the selection has been canceled.
#: addon\appModules\mp3directcut.py:98
msgid "Selection canceled."
msgstr "Selecție anulată"

#: addon\appModules\mp3directcut.py:244
msgid "of"
msgstr "din"

#: addon\appModules\mp3directcut.py:245
msgid "Part"
msgstr "Parte"

#. Translators: Message to inform the user that there is no remaining time.
#: addon\appModules\mp3directcut.py:327
msgid "No time remaining !"
msgstr "Fără timp rămas!"

#. Translators: Message to indicate the elapsed time.
#: addon\appModules\mp3directcut.py:499 addon\appModules\mp3directcut.py:533
#: addon\appModules\mp3directcut.py:555 addon\appModules\mp3directcut.py:558
msgid "Elapsed time: "
msgstr "Timp scurs:"

#. Translators, Message presented in input help mode.
#: addon\appModules\mp3directcut.py:539
msgid "Gives the duration from the beginning of the file to the current position of the playback cursor.\t\t\tIf pressed twice, gives the total duration."
msgstr ""

#. Translators: Message presented in input help mode.
#: addon\appModules\mp3directcut.py:568
msgid "Gives the time remaining from the current position of the playback cursor to the end of the file."
msgstr "Afișează timpul rămas de la poziția curentă a cursorului de redare până la sfârșitul fișierului."

#. Translators: Message to indicate the remaining time.
#: addon\appModules\mp3directcut.py:581
msgid "Remaining time: "
msgstr "Timp rămas"

#. Translators: Message presented in input help mode.
#: addon\appModules\mp3directcut.py:586
msgid "Used to determine the current level of the vu-meter, during recording, double pressure reset it."
msgstr "Utilizat pentru a determina nivelul curent a vu-meter-ului, în timpul înregistrării. Dacă este apăsat de două ori, îl va reseta."

#. Translators: Message presented in input help mode.
#: addon\appModules\mp3directcut.py:636
msgid "Used to indicate the position of the marker of the beginning of selection B.\t\t\tDouble pressure lets give you the duration of the selection."
msgstr ""

#. Translators: Message presented in input help mode.
#: addon\appModules\mp3directcut.py:657
msgid "Used to indicate the position of the marker of the end of selection N.\t\t\tDouble pressure gives recapitulatif positions B and N, and the duration of the selection."
msgstr ""

#. Translators: Message presented in input help mode.
#: addon\appModules\mp3directcut.py:681
msgid "Give the reference of the actual part and the total number of parts in the current file."
msgstr "Afișează referința părții actuale și numărul total de părți în fișierul curent."

#: addon\appModules\mp3directcut.py:735
msgid "Lets open the help of the current add-on."
msgstr "Hai să Deschidem ghidul de utilizare al suplimentului curent."

